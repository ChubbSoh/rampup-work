# Lead relay — server-side only, never NEXT_PUBLIC_
# URL of the n8n lead webhook (production URL from your workflow)
N8N_LEAD_WEBHOOK_URL=

# Cloudflare Turnstile — CAPTCHA protection for lead form
# Get from: https://dash.cloudflare.com/ → Turnstile → Add site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=   # public — used to render the widget
TURNSTILE_SECRET_KEY=             # server-side only — used to verify tokens

# Control panel password — server-side only, never NEXT_PUBLIC_
# Set this in Netlify: Site Settings → Environment Variables
CONTROL_PANEL_PASSWORD=

# n8n internal webhook URLs — server-side only, never NEXT_PUBLIC_
# Copy from n8n: your workflow webhook node → Production URL
N8N_ONBOARD_WEBHOOK_URL=
N8N_PUBLISH_WEBHOOK_URL=

# Shared secret sent as X-Internal-Token header on all internal n8n calls
# Generate with: openssl rand -hex 32
# Must also be configured in n8n webhook nodes to validate the header
N8N_INTERNAL_WEBHOOK_TOKEN=

# Upload assets (admin panel → Cloudflare Images → clients.json → Netlify rebuild)
# CF_ACCOUNT_ID: Cloudflare account ID (dash.cloudflare.com → right sidebar)
# CF_IMAGES_TOKEN: API token with Cloudflare Images:Edit permission
# GITHUB_TOKEN: Personal access token with repo scope (github.com → Settings → Tokens)
CF_ACCOUNT_ID=
CF_IMAGES_TOKEN=
GITHUB_TOKEN=

# Cloudflare Stream — server-side only, never NEXT_PUBLIC_
# Customer code: found in your Stream dashboard URL (customer-XXXXXXXX)
CLOUDFLARE_STREAM_CUSTOMER_CODE=
# Signing key ID + private key: only needed if you enable signed URL delivery in Stream
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_SIGNING_PRIVATE_KEY=
