# n8n webhook — triggered on successful lead form submission
# Set this in Netlify: Site Settings → Environment Variables
NEXT_PUBLIC_N8N_LEAD_WEBHOOK_URL=

# Control panel password — server-side only, never NEXT_PUBLIC_
# Set this in Netlify: Site Settings → Environment Variables
CONTROL_PANEL_PASSWORD=

# n8n internal webhook URLs — server-side only, never NEXT_PUBLIC_
# Copy from n8n: your workflow webhook node → Production URL
N8N_ONBOARD_WEBHOOK_URL=
N8N_PUBLISH_WEBHOOK_URL=

# Shared secret sent as X-Internal-Token header on all internal n8n calls
# Generate with: openssl rand -hex 32
# Must also be configured in n8n webhook nodes to validate the header
N8N_INTERNAL_WEBHOOK_TOKEN=
